        "lastDeliveryStatus": "unknown",
        "consecutiveErrors": 1,
        "lastError": "cron: job execution timed out",
        "lastErrorReason": "timeout"
      }
    },
    {
      "id": "b126e2f4-41a7-4edb-a5dc-3121ae27e112",
      "agentId": "beta",
      "name": "上下文监控与压缩",
      "description": "每30分钟监控主会话上下文使用率，超过80%立即压缩，仅在触发压缩时汇报，否则完全静默",
      "enabled": true,
      "createdAtMs": 1773410334940,
      "updatedAtMs": 1773945004817,
      "schedule": {
        "kind": "cron",
        "expr": "*/30 * * * *"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "任务：监控主会话上下文使用率。步骤：1. 使用 session_status 检查当前主会话的上下文使用率（totalTokens / contextTokens * 100）2. 如果使用率超过80%，立即启动压缩（compaction）3. 如果触发了压缩，向梦想家报告结果（包括使用率、是否压缩）4. 如果没有触发压缩（使用率未超过80%），不向梦想家汇报，直接结束。注意：只监控主会话（当前会话），不检查其他会话。不要主动向梦想家汇报，除非触发了压缩。按照梦想家指令：完全静默，除非触发压缩。",
        "timeoutSeconds": 180
      },
      "delivery": {
        "mode": "none"
      },
      "state": {
        "nextRunAtMs": 1773946800000,
        "lastRunAtMs": 1773945000009,
        "lastRunStatus": "ok",
        "lastStatus": "ok",
        "lastDurationMs": 4808,
        "lastDeliveryStatus": "not-delivered",
        "consecutiveErrors": 0,
        "lastDelivered": false
