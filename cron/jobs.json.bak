    {
      "id": "dccd3222-f72e-49b7-99c4-d0ede503947c",
      "agentId": "lambda",
      "name": "全局 Inbox 高频轮询",
      "description": "即时通讯v2.1：每3分钟扫描inbox，触发未读消息处理",
      "enabled": true,
      "createdAtMs": 1773885055543,
      "updatedAtMs": 1773943344067,
      "schedule": {
        "kind": "every",
        "everyMs": 300000,
        "anchorMs": 1773923361372
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "全局 inbox 扫描：先运行脚本更新 .last-read 和扫描未读消息，只输出高优先级消息摘要（不超过 300 字）。\n\n```bash\n# 步骤 1：更新所有 Agent 的 .last-read\ncd /home/gang/.openclaw/workspace-lambda\nfor agent in alpha beta lambda delta epsilon eta gamma iota kappa theta zeta; do\n  ./inbox-updater.sh \"/home/gang/.openclaw/workspace-$agent\" 2>/dev/null\ndone\n\n# 步骤 2：扫描未读消息（只看 .last-read 之后的新文件）\necho \"=== 未读消息扫描 ===\"\nfor agent in alpha beta lambda delta epsilon eta gamma iota kappa theta zeta; do\n  INBOX=\"/home/gang/.openclaw/workspace-$agent/inbox\"\n  LAST_READ=$(cat \"$INBOX/.last-read\" 2>/dev/null | tr -d \"\\n\")\n  if [ -n \"$LAST_READ\" ] && [ -f \"$INBOX/$LAST_READ\" ]; then\n    NEW=$(find \"$INBOX\" -name \"msg-*.json\" -newer \"$INBOX/$LAST_READ\" 2>/dev/null | sort)\n    if [ -n \"$NEW\" ]; then\n      COUNT=$(echo \"$NEW\" | wc -l)\n      echo \"📨 $agent: $COUNT 条新消息\"\n      # 只显示前 2 条的 subject\n      echo \"$NEW\" | head -2 | while read f; do\n        SUBJECT=$(grep -o \"\\\"subject\\\"\\\\s*:\\\\s*\\\"[^\\\"]*\\\"\" \"$f\" 2>/dev/null | head -1 | sed \"s/.*\\\"subject\\\"\\\\s*:\\\\s*\\\"//;s/\\\"$//\")\n        PRIORITY=$(grep -o \"\\\"priority\\\"\\\\s*:\\\\s*\\\"[^\\\"]*\\\"\" \"$f\" 2>/dev/null | head -1 | sed \"s/.*\\\"priority\\\"\\\\s*:\\\\s*\\\"//;s/\\\"$//\")\n        [ -n \"$SUBJECT\" ] && echo \"  [$PRIORITY] $SUBJECT\"\n      done\n    fi\n  fi\ndone\n```\n\n如果有 urgent/critical 消息，立即高亮显示。其他消息只需列出数量。",
        "lightContext": true,
        "timeoutSeconds": 300
      },
      "delivery": {
        "mode": "announce",
        "channel": "last"
      },
